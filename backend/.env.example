# MongoDB
MONGODB_URL=mongodb://admin:admin123@localhost:27017
MONGODB_DB_NAME=empathy_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Environment
ENVIRONMENT=development
DEBUG=true

# AWS (will populate in Phase 2)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-key-here

# SQS (will populate in Phase 1 Day 3)
SQS_INTERACTIONS_QUEUE=https://sqs.region.amazonaws.com/account/empathy-interactions
SQS_ERRORS_QUEUE=https://sqs.region.amazonaws.com/account/empathy-errors

# Gemini API (will populate in Phase 2)
GEMINI_API_KEY=your-gemini-key-here
